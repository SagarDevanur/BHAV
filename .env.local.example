# ============================================================
# BHAV Acquisition Corp — environment variables
# Copy this file to .env.local and fill in every value.
# Never commit .env.local to version control.
# All variables are accessed exclusively via lib/config.ts.
# ============================================================

# ------------------------------------------------------------
# Supabase
# Get these from: Supabase dashboard → Project Settings → API
# ------------------------------------------------------------

# Public URL of your Supabase project (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key — enforces Row Level Security (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — bypasses RLS. SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Clerk
# Get these from: Clerk dashboard → API Keys
# ------------------------------------------------------------

# Publishable key — safe to expose to browser
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Secret key — SERVER ONLY. Used to verify sessions server-side.
CLERK_SECRET_KEY=

# Webhook signing secret — SERVER ONLY. Used to verify Clerk webhook payloads.
# Get from: Clerk dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=

# URL Clerk redirects to for sign-in (default: /sign-in)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# URL Clerk redirects to after successful sign-in (default: /)
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# ------------------------------------------------------------
# Anthropic
# Primary LLM. Get from: console.anthropic.com → API Keys
# SERVER ONLY — never expose to the browser.
# ------------------------------------------------------------

ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# OpenAI
# Fallback LLM used when Anthropic API fails. SERVER ONLY.
# Get from: platform.openai.com → API Keys
# ------------------------------------------------------------

OPENAI_API_KEY=

# ------------------------------------------------------------
# Upstash Redis (BullMQ job queue)
# Get from: console.upstash.com → your Redis database → REST API
# SERVER ONLY — never expose to the browser.
# ------------------------------------------------------------

# REST API URL for your Upstash Redis database
UPSTASH_REDIS_REST_URL=

# REST API auth token for your Upstash Redis database
UPSTASH_REDIS_REST_TOKEN=

# ------------------------------------------------------------
# App
# ------------------------------------------------------------

# Full public URL of the app (used for absolute URL generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# Google News API (optional)
# Used by the Sourcing agent to search recent news for target companies.
# Get a free key from: newsapi.org → Get API Key
# SERVER ONLY — never expose to the browser.
# ------------------------------------------------------------

GOOGLE_NEWS_API_KEY=

# ------------------------------------------------------------
# Hunter.io API (optional)
# Used by the Contact agent to find email addresses by domain.
# Get a free key from: hunter.io → Sign Up → API
# SERVER ONLY — never expose to the browser.
# ------------------------------------------------------------

HUNTER_API_KEY=
